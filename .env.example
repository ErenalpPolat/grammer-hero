# ============================================================
# Grammar Hero · Environment Variables
# ============================================================
# Local geliştirme için bu dosyayı `.env.local` olarak kopyala
# ve değerleri doldur. `.env.local` git'e commit edilmez.
# ============================================================

# --- Database ---
# PostgreSQL bağlantı string'i.
# Unix socket (Linux dev):
#   postgresql://USER@localhost/DBNAME?host=/var/run/postgresql&schema=public
# TCP (docker / managed / Vercel Postgres):
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
# Vercel Postgres pooled URL — connection pooling için
#   postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://USER@localhost/grammar_hero?host=/var/run/postgresql&schema=public"

# --- Auth (NextAuth v5) ---
# JWT imzalama anahtarı (32+ karakter base64).
# Üret: openssl rand -base64 32
AUTH_SECRET="change-me-min-32-char-base64-random"

# Production'da kullanılmayacak (sadece dev). Production'da Vercel/host
# zaten doğru host header'larını gönderir.
AUTH_TRUST_HOST="true"

# --- Site URL ---
# Production: https://grammar-hero.vercel.app gibi tam domain
# Dev: http://localhost:3000
# Sitemap, robots.txt, Open Graph, manifest start_url için kullanılır.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Web Push (opsiyonel) ---
# VAPID anahtar çifti — tarayıcı bildirimleri için.
# Üret: npx web-push generate-vapid-keys
# (çıktıdaki "Public Key" → her iki aşağıdaki var'a, "Private Key" → VAPID_PRIVATE_KEY'e)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY client'ta push subscribe için kullanılır,
# VAPID_PRIVATE_KEY yalnızca server tarafında web-push'un imzalaması için.
# VAPID_SUBJECT: mailto: veya https: URL (contact bilgisi — push endpoint'lerinin gereksinimi).
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:admin@example.com"

# --- Logging / Observability (opsiyonel) ---
# SENTRY_DSN=""
# AXIOM_TOKEN=""
